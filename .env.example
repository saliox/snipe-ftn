# Identifiants du client OAuth Epic utilisés pour l'échange de token.
# Par défaut (si non renseigné) : fortniteIOSGameClient, largement connu.
# Tu peux les surcharger ici si tu utilises un autre client de jeu Epic.
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=

# Optionnel : dossier de stockage du token chiffré (défaut : ./data)
# SNIPE_DATA_DIR=

# --- Auto-update ---
# Par défaut : Releases GitHub de saliox/snipe-ftn (autonome, aucune config).
# Surcharge possible :
#   UPDATE_REPO=owner/name        (autre dépôt GitHub)
#   UPDATE_URL=http://ip:8770/    (flux HTTP local, voir npm run serve:updates)
# UPDATE_REPO=
# UPDATE_URL=

# Mettre à 1 pour afficher les stacktraces complètes en cas d'erreur.
# DEBUG=
